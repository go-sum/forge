# .env.example — Copy to .env and fill in values for your environment
# .env is gitignored and canonical per-server (dev or production).
# Hostnames use docker-compose service names: db, kv.
#
# Setup:
#   cp .env.example .env
#   vim .env
#

# ── Application ─────────────────────────────────────────────────────────────
# Set to "development" on dev machines; defaults to "production" if unset.
APP_ENV=development
APP_PORT=8080
EXTERNAL_ORIGIN=https://forge.test

# ── Database ────────────────────────────────────────────────────────────────
# DATABASE_URL is the app connection string (used by Go code).
# PG* vars configure the postgres container via docker-compose; plan/test databases
# are created by db/init-dev/01-databases.sh.
DATABASE_URL=postgres://postgres:postgres@db:5432/starter?sslmode=disable
PGHOST=db
PGPORT=5432
PGDATABASE=starter
PGUSER=postgres
PGPASSWORD=postgres

# ── Session / Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SESSION_AUTH_KEY=
# Generate with: openssl rand -hex 16
AUTH_SESSION_ENCRYPT_KEY=

# ── CSRF ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
SECURITY_CSRF_KEY=

# ── Email (pkg/send) ───────────────────────────────────────────────────────
EMAIL_API_KEY=

# ── GitHub (package sync) ──────────────────────────────────────────────────
# https://github.com/settings/tokens — only needed for package publishing
PACKAGE_SYNC_TOKEN=

# ── KV (Dragonfly/Redis) ───────────────────────────────────────────────────
# Hostname "kv" matches the docker-compose service name.
KV_HOST=kv
KV_PORT=6379
KV_PASSWORD=
