# .env.example — Copy to .env and fill in values for your environment
#
# Setup:
#   cp .env.example .env
#   vim .env
#
# .env is gitignored and canonical per-server (dev or production).
# Hostnames use docker-compose service names: db, kv, test_db, test_kv.

# ── Application ─────────────────────────────────────────────────────────────
# Set to "development" on dev machines; defaults to "production" if unset.
APP_ENV=development
APP_PORT=8080

# ── Database ────────────────────────────────────────────────────────────────
# Hostname "db" matches the docker-compose service name.
DATABASE_URL=postgres://postgres:postgres@db:5432/starter?sslmode=disable
PGHOST=db
PGPORT=5432
PGDATABASE=starter
PGUSER=postgres
PGPASSWORD=postgres

# ── Session / Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SESSION_AUTH_KEY=
# Generate with: openssl rand -hex 16
AUTH_SESSION_ENCRYPT_KEY=

# ── CSRF ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
SECURITY_CSRF_KEY=

# ── Email (pkg/send) ───────────────────────────────────────────────────────
EMAIL_API_KEY=

# ── GitHub (package sync) ──────────────────────────────────────────────────
# https://github.com/settings/tokens — only needed for package publishing
PACKAGE_SYNC_TOKEN=

# ── KV (Dragonfly/Redis) ───────────────────────────────────────────────────
# Hostname "kv" matches the docker-compose service name.
KV_HOST=kv
KV_PORT=6379
KV_PASSWORD=

# ── KV Test ────────────────────────────────────────────────────────────────
KVTEST_HOST=test_kv
KVTEST_PORT=6379
KVTEST_PASSWORD=
TEST_KV_URL=redis://test_kv:6379

# ── pgschema plan database ────────────────────────────────────────────────
# Scratch database for safe diff computation — never touches PGDATABASE.
PGSCHEMA_PLAN_HOST=schema_data
PGSCHEMA_PLAN_DB=postgres
PGSCHEMA_PLAN_USER=postgres
PGSCHEMA_PLAN_PASSWORD=postgres

# ── Test database ──────────────────────────────────────────────────────────
# Ephemeral test DB (tmpfs) — used by go test via TEST_DATABASE_URL.
TEST_DATABASE_URL=postgres://postgres:postgres@test_db:5432/starter_test?sslmode=disable
PGTEST_HOST=test_db
PGTEST_PORT=5432
PGTEST_DATABASE=starter_test
PGTEST_USER=postgres
PGTEST_PASSWORD=postgres
